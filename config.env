# Single-node vLLM service config (dotenv format)
# Used by docker-compose as both runtime env and compose env source

PROJECT_NAME=vllm-single
CONTAINER_NAME=vllm-single

VLLM_IMAGE=nvcr.io/nvidia/vllm:25.11-py3
MODEL=openai/gpt-oss-120b

VLLM_PORT=8000
TENSOR_PARALLEL=1
MAX_MODEL_LEN=8192
GPU_MEMORY_UTIL=0.90
SWAP_SPACE=16
SHM_SIZE=16g

HF_CACHE=/raid/hf-cache
HF_TOKEN=

ENABLE_EXPERT_PARALLEL=true
TRUST_REMOTE_CODE=false
LOAD_FORMAT=safetensors
EXTRA_ARGS=

NCCL_DEBUG=WARN
